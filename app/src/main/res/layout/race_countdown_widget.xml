<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical">

    <!-- Race Countdown Row -->
    <LinearLayout
        android:id="@+id/widget_countdown_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/widget_days_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="@color/widget_accent_green"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_marginEnd="10dp"
            android:includeFontPadding="false"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">
            
            <TextView
                android:id="@+id/widget_days_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ngày còn lại"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:ellipsize="end"
                android:maxLines="1"/>

            <TextView
                android:id="@+id/widget_target"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎯 21.0 km"
                android:textColor="@color/widget_accent_indigo"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Section Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HÔM NAY"
        android:textColor="@color/widget_text_secondary"
        android:textSize="9sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"
        android:letterSpacing="0.08"/>

    <!-- Today's Workout Card Container -->
    <LinearLayout
        android:id="@+id/widget_workout_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@drawable/widget_workout_card_bg"
        android:gravity="center_vertical">

        <!-- Status Icon -->
        <ImageView
            android:id="@+id/widget_workout_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="10dp"
            android:src="@drawable/ic_widget_run"
            android:contentDescription="Workout Icon"/>

        <!-- Workout Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_workout_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Đang tải..."
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"/>

            <TextView
                android:id="@+id/widget_workout_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
