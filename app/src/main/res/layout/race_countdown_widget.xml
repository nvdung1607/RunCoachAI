<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    android:background="@drawable/widget_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="10dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RunCoach AI"
            android:textColor="#8E8E93"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/widget_days_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#A3E635"
            android:textSize="32sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/widget_days_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ngày đến ngày đua"
            android:textColor="#F3F4F6"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/widget_target"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mục tiêu: --km"
            android:textColor="#818CF8"
            android:textSize="11sp"
            android:layout_marginTop="2dp"/>

    </LinearLayout>
</RelativeLayout>
